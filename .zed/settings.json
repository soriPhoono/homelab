{
  "lsp": {
    "nil": {
      "settings": {
        "nix": {
          "flake": {
            "autoEvalInputs": true,
          },
        },
      },
    },
    "nixd": {
      "settings": {
        "nixpkgs": {
          // Tells nixd how to evaluate standard nixpkgs.
          // For Flakes, you can point this to your flake's inputs.
          "expr": "import (builtins.getFlake (builtins.toString ./.)).inputs.nixpkgs { }",
        },
        "options": {
          // Allows nixd to provide autocompletion for NixOS module options
          "nixos": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.zephyrus.options",
          },
          // Allows nixd to provide autocompletion for Home Manager module options
          "home-manager": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).homeConfigurations.sphoono@zephyrus.options",
          },
        },
      },
    },
  },
  // Optionally, map the Nix formatter to the default Zed formatting behavior
  "languages": {
    "Nix": {
      "formatter": {
        "external": {
          "command": "alejandra",
          "arguments": ["--quiet", "--"],
        },
      },
    },
  },
}
